<Window x:Class="RPGCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание персонажа RPG" Height="500" Width="600">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Имя персонажа -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Имя персонажа:" FontWeight="Bold" FontSize="14"/>
            <TextBox x:Name="NameTextBox" Margin="0,5,0,0" Height="25"/>
        </StackPanel>

        <!-- Выбор класса -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Класс персонажа:" FontWeight="Bold" FontSize="14"/>
            <RadioButton x:Name="WarriorRadio" Content="Воин" GroupName="Class" Margin="0,5,0,0" IsChecked="True"/>
            <RadioButton x:Name="MageRadio" Content="Маг" GroupName="Class"/>
            <RadioButton x:Name="ArcherRadio" Content="Лучник" GroupName="Class"/>
            <RadioButton x:Name="RogueRadio" Content="Вор" GroupName="Class"/>
        </StackPanel>

        <!-- Выбор навыков -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="Навыки (выберите несколько):" FontWeight="Bold" FontSize="14"/>
            <CheckBox x:Name="SmithingCheck" Content="Кузнечное дело" Margin="0,5,0,0"/>
            <CheckBox x:Name="AlchemyCheck" Content="Алхимия"/>
            <CheckBox x:Name="PotionCheck" Content="Зельеварение"/>
            <CheckBox x:Name="LockpickCheck" Content="Взлом замков"/>
            <CheckBox x:Name="StealthCheck" Content="Скрытность"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="CreateButton" Content="Создать персонажа" Width="150" Height="30" Click="CreateButton_Click"/>
            <Button x:Name="ResetButton" Content="Сбросить" Width="100" Height="30" Margin="10,0,0,0" Click="ResetButton_Click"/>
            <Button x:Name="RandomButton" Content="Случайный выбор" Width="150" Height="30" Margin="10,0,0,0" Click="RandomButton_Click"/>
        </StackPanel>

        <!-- Результат -->
        <GroupBox Grid.Row="4" Header="Информация о персонаже">
            <ScrollViewer>
                <TextBox x:Name="ResultTextBox" TextWrapping="Wrap" Padding="10" FontSize="12" IsReadOnly="True" Background="#F0F0F0"/>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>